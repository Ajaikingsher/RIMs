# RIMS Software Company — Environment Variables
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_SITE_URL=https://www.rimssoftware.com
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# Email (Nodemailer — fill in to enable contact form emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=contact@rimssoftware.com
CONTACT_RECEIVER=contact@rimssoftware.com

# PostgreSQL (optional — for future DB integration)
DATABASE_URL=postgresql://user:password@localhost:5432/rims_db
